# ===========================================
# BodyLog 環境変数
# ===========================================
# このファイルを .env.local にコピーして値を設定してください
#   cp .env.example .env.local

# --- Supabase ---
# Supabase ダッシュボード > Settings > API Keys で取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# --- Gemini AI（OCR 用） ---
# https://aistudio.google.com で API キーを作成
GEMINI_API_KEY=your-gemini-api-key

# --- 認証 ---
# (非推奨) 旧ログインパスワード。現在は Supabase Auth 移行のため不要です。
# APP_PASSWORD=changeme

# JWT 署名用シークレット（以下のコマンドで生成: openssl rand -base64 32）
NEXTAUTH_SECRET=your-random-secret

# アプリの URL（Vercel では自動設定されるため通常は不要）
# NEXTAUTH_URL=http://localhost:3000
